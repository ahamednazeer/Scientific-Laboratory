APP_ENV=development
DATABASE_URL=sqlite:///./lab_ar.db
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
DETECTOR_MODE=mock
DETECTOR_ARCH=tf_efficientdet_d2
DETECTOR_WEIGHTS_PATH=models/efficientdet_lab_instruments.pth
DETECTOR_LABEL_MAP_PATH=models/class_labels.json
DETECTOR_DEVICE=auto
DETECTOR_INPUT_SIZE=768
DETECTOR_MAX_DETECTIONS=50
DETECTOR_CLASS_INDEX_BASE=1
DETECTOR_USE_FP16=false
DETECTION_CONFIDENCE_THRESHOLD=0.35
NMS_IOU_THRESHOLD=0.45

# Optional
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Optional JSON array or comma-separated list:
# GROQ_VISION_FALLBACK_MODELS=["meta-llama/llama-4-maverick-17b-128e-instruct","llama-3.2-90b-vision-preview"]
